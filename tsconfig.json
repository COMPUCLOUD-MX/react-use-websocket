{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist/",
    "sourceMap": true,
    "module": "commonjs",
    "esModuleInterop": true,
    "target": "es6",
    "jsx": "react",
    "skipLibCheck": true,
    "lib": ["es2017", "dom"],
    "types": ["node", "websocket", "jest"],
    "strict": true,
    "declaration": true,
    "paths": {
      "@lib/*": ["./src/lib/*"]
    }
  },
  "files": ["./src/index.ts"],
  "include": ["src/*"]
}
